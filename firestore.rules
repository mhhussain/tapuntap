rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /decks/{deckId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        match /versions/{v} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }

    match /cards/{cardId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /games/{gameId} {
      function isParticipant() {
        return request.auth != null && request.auth.uid in resource.data.seatUids;
      }
      function onlyTurnFields() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['turn', 'activeSeat', 'phase', 'phaseIndex', 'updatedAt']);
      }

      allow read: if request.auth != null && (isParticipant() || resource.data.status == 'lobby');
      allow update: if isParticipant() && onlyTurnFields()
        && resource.data.turnOrder[resource.data.activeSeat] == request.auth.uid;
      allow update: if isParticipant() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notes', 'updatedAt']) &&
        'notes' in request.resource.data.diff(resource.data).affectedKeys();
      allow delete: if request.auth != null && resource.data.hostUid == request.auth.uid;

      match /log/{entryId} {
        allow read: if isParticipant();
        allow create: if isParticipant();
      }

      match /players/{uid} {
        allow read: if isParticipant();
        allow write: if request.auth != null && request.auth.uid == uid;

        match /private/{docId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }

    match /{document=**} { allow read, write: if false; }
  }
}
